# ============================================
# Rekrut AI - Environment Variables Template
# Copy this to .env and fill in your real keys
# NEVER commit .env to git (it's in .gitignore)
# ============================================

# ============================================
# AI PROVIDER KEYS (Required for AI features)
# ============================================

# PRIMARY: Polsia AI Proxy (Required)
# Get from: https://polsia.com (or your Polsia account)
POLSIA_API_KEY=your_polsia_api_key_here
POLSIA_API_URL=https://polsia.com/api/proxy/ai

# FALLBACK 1: OpenAI (Recommended)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# FALLBACK 2: NVIDIA NIM (Recommended)
# Get from: https://build.nvidia.com/explore (free tier available)
NVIDIA_NIM_API_KEY=your_nvidia_nim_key_here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# FALLBACK 3: Groq (Optional but fast)
# Get from: https://console.groq.com (free tier available)
GROQ_API_KEY=your_groq_key_here

# FALLBACK 4: Cerebras (Optional)
# Get from: https://cerebras.ai (enterprise)
CEREBRAS_API_KEY=your_cerebras_key_here

# AUDIO: Deepgram (Required for TTS/STT)
# Get from: https://console.deepgram.com ($200 free credit)
DEEPGRAM_API_KEY=your_deepgram_key_here

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://username:password@host:5432/database

# ============================================
# SESSION & SECURITY
# ============================================
SESSION_SECRET=your_random_session_secret_here_change_in_production
PORT=3000
NODE_ENV=development

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
